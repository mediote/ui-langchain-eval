# --- Azure OpenAI ---
# URL do recurso Azure OpenAI (encontrado no portal Azure > seu recurso > Keys and Endpoint)
AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com/"
# Chave de autenticação da API (Key 1 ou Key 2 no portal)
AZURE_OPENAI_API_KEY="<your-api-key>"
# Versão da API do Azure OpenAI a utilizar
AZURE_OPENAI_API_VERSION="2025-03-01-preview"
# Nome do deployment criado no Azure AI Foundry (ex: gpt-4o, gpt-5-chat)
AZURE_OPENAI_DEPLOYMENT_NAME="<your-deployment-name>"

# --- Autenticação Entra ID ---
# Desabilitar em dev (AUTH_ENABLED=false usa usuário mock)
AUTH_ENABLED=false
# ID do tenant do Azure AD (portal Azure > Entra ID > Overview > Tenant ID)
AZURE_AD_TENANT_ID="<your-tenant-id>"
# Client ID do app registration que o frontend usa no MSAL
AZURE_AD_CLIENT_ID="<your-client-id>"

# --- Langfuse (observabilidade self-hosted) ---
# Chaves geradas em http://localhost:3000 após criar um projeto
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://host.docker.internal:3000

# --- LangSmith (observabilidade) ---
# Habilitar tracing automático de todas as chamadas LangChain/LangGraph
LANGCHAIN_TRACING_V2=true
# API Key do LangSmith (smith.langchain.com > Settings > API Keys)
LANGCHAIN_API_KEY="ls__<your-api-key>"
# Nome do projeto que aparece no dashboard (opcional, padrão: "default")
LANGCHAIN_PROJECT="ssma-agent"

# --- Azure Cosmos DB for MongoDB vCore (memória multi-turn) ---
# Connection string do Cosmos DB com API MongoDB (portal Azure > seu cluster > Connection strings)
COSMOS_CONN_STRING="mongodb+srv://<user>:<password>@<cluster>.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000"
# Nome do banco de dados onde os checkpoints serão armazenados (opcional, padrão: langgraph)
COSMOS_DB="langgraph"
